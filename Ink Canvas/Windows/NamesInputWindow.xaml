<Window
    x:Class="Ink_Canvas.NamesInputWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Ink_Canvas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="名单导入 - 抽奖 - Ink Canvas Ultra"
    Width="400"
    Height="500"
    ui:ThemeManager.RequestedTheme="Light"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="False"
    Closing="Window_Closing"
    Loaded="Window_Loaded"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Border
        Margin="10"
        Padding="20"
        Background="{DynamicResource PopupWindowBackground}"
        BorderBrush="{DynamicResource PopupWindowBorderBrush}"
        BorderThickness="1"
        CornerRadius="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- 头部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock
                    Margin="0,0,8,0"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource PopupWindowForeground}"
                    Text="名单导入" />
                <Border
                    Padding="6,2"
                    Background="{DynamicResource PopupWindowDarkBlueBorderBackground}"
                    CornerRadius="4">
                    <TextBlock
                        FontSize="13"
                        Foreground="{DynamicResource PopupWindowDarkBlueBorderForeground}"
                        Text="抽奖" Height="18" />
                </Border>
            </StackPanel>
        </Grid>
        
        <TextBox
            Grid.Row="1"
            Name="TextBoxNames"
            Margin="0,0,0,15"
            AcceptsReturn="True"
            Foreground="{DynamicResource PopupWindowForeground}"
            VerticalScrollBarVisibility="Auto" />
        <Button
            Grid.Row="2"
            Width="100"
            HorizontalAlignment="Right"
            Click="Button_Click"
            Content="关闭" />
    </Grid>
    </Border>
</Window>
