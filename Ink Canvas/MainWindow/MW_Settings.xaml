<Window
    x:Class="Ink_Canvas.MW_Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:Ink_Canvas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    Title="设置 - Ink Canvas Ultra"
    Width="900"
    Height="620"
    MinWidth="700"
    MinHeight="500"
    ui:ThemeManager.RequestedTheme="Light"
    ui:WindowHelper.SystemBackdropType="Mica"
    ui:WindowHelper.UseModernWindowStyle="False"
    WindowStartupLocation="CenterScreen"
    Topmost="True"
    mc:Ignorable="d">
    <Border
        Margin="10"
        Padding="20"
        Background="{DynamicResource PopupWindowBackground}"
        BorderBrush="{DynamicResource PopupWindowBorderBrush}"
        BorderThickness="1"
        CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 头部标题栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,8,0"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PopupWindowForeground}"
                        Text="设置" />
                    <Border
                        Padding="6,2"
                        Background="{DynamicResource PopupWindowDarkBlueBorderBackground}"
                        CornerRadius="4">
                        <TextBlock
                            FontSize="13"
                            Foreground="{DynamicResource PopupWindowDarkBlueBorderForeground}"
                            Text="Ink Canvas Ultra"
                            Height="18" />
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 主内容区 -->
            <ui:NavigationView

                Grid.Row="1"

                x:Name="SettingsNavigationView"

                PaneDisplayMode="Left"

                OpenPaneLength="200"

                CompactPaneLength="48"

                IsBackButtonVisible="Collapsed"

                IsSettingsVisible="False"

                IsPaneToggleButtonVisible="True"

                SelectionChanged="SettingsNav_SelectionChanged"

                AlwaysShowHeader="False">

                <ui:NavigationView.PaneHeader>

                    <TextBlock

                        Margin="16,12,0,8"

                        FontSize="12"

                        FontWeight="SemiBold"

                        Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                        Text="导航" />

                </ui:NavigationView.PaneHeader>

                <ui:NavigationView.MenuItems>

                    <ui:NavigationViewItem Content="概览" Tag="Overview">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xE80F;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItemSeparator />

                    <ui:NavigationViewItemHeader Content="设置项" />

                    <ui:NavigationViewItem Content="启动" Tag="Startup">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xE7B8;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="画板" Tag="Board">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xEE56;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="手势" Tag="Gesture">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xEDA5;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="墨迹识别" Tag="InkRecognition">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xE787;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="外观" Tag="Appearance">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xE771;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="PPT" Tag="PPT">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xE8B9;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="高级" Tag="Advanced">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xE81E;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                    <ui:NavigationViewItem Content="自动" Tag="Auto">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xEC4A;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                </ui:NavigationView.MenuItems>

                <ui:NavigationView.FooterMenuItems>

                    <ui:NavigationViewItem Content="关于" Tag="About">

                        <ui:NavigationViewItem.Icon>

                            <ui:FontIcon FontSize="16" Glyph="&#xE946;" />

                        </ui:NavigationViewItem.Icon>

                    </ui:NavigationViewItem>

                </ui:NavigationView.FooterMenuItems>

                <!-- 右侧内容区域 -->

                <Grid>

                <ui:ScrollViewerEx

                    x:Name="SettingsScrollViewer"

                    Margin="0,0,0,50"

                    ManipulationBoundaryFeedback="SCManipulationBoundaryFeedback"

                    PanningMode="VerticalOnly"

                    VerticalScrollBarVisibility="Auto">

                    <StackPanel Margin="20,20,20,20">

                        <Border

                            x:Name="SettingsSection_Overview"

                            Height="140"

                            Margin="0,0,0,15"

                            BorderBrush="{DynamicResource PopupWindowBorderBrush}"

                            BorderThickness="1"

                            CornerRadius="5">

                            <ikw:SimpleStackPanel VerticalAlignment="Center">

                                <TextBlock

                                    Margin="0,0,0,15"

                                    HorizontalAlignment="Center"

                                    VerticalAlignment="Center"

                                    FontSize="15"

                                    Foreground="{DynamicResource PopupWindowForeground}"

                                    Text="设置更改将自动保存，部分设置需要重启软件后生效" />

                                <ikw:SimpleStackPanel Spacing="10">

                                    <ikw:SimpleStackPanel

                                        HorizontalAlignment="Center"

                                        Orientation="Horizontal"

                                        Spacing="10">

                                        <Button

                                            Width="115"

                                            Height="40"

                                            Click="BtnRestart_Click">

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Orientation="Horizontal"

                                                Spacing="0">

                                                <ui:FontIcon

                                                    Margin="0,1,4,0"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource PopupWindowForeground}"

                                                    Glyph="&#xe72c;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    FontSize="16"

                                                    FontWeight="Bold">

                                                    重启软件

                                                </Label>

                                            </ikw:SimpleStackPanel>

                                        </Button>

                                        <Button

                                            Width="115"

                                            Height="40"

                                            Click="BtnResetToSuggestion_Click"

                                            FontWeight="Bold">

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Orientation="Horizontal"

                                                Spacing="0">

                                                <ui:FontIcon

                                                    Margin="0,0,4,0"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="18"

                                                    Foreground="{DynamicResource PopupWindowForeground}"

                                                    Glyph="&#xe8f7;" />

                                                <Label

                                                    Margin="2,0,0,0"

                                                    VerticalAlignment="Center"

                                                    FontSize="16"

                                                    FontWeight="Bold">

                                                    重置设置

                                                </Label>

                                            </ikw:SimpleStackPanel>

                                        </Button>

                                        <Button

                                            Width="115"

                                            Height="40"

                                            Click="BtnExit_Click">

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Orientation="Horizontal"

                                                Spacing="0">

                                                <ui:FontIcon

                                                    Margin="0,0,4,0"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="18"

                                                    Foreground="{DynamicResource PopupWindowForeground}"

                                                    Glyph="&#xe7e8;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    FontSize="16"

                                                    FontWeight="Bold">

                                                    关闭软件

                                                </Label>

                                            </ikw:SimpleStackPanel>

                                        </Button>

                                    </ikw:SimpleStackPanel>

                                    <ikw:SimpleStackPanel

                                        HorizontalAlignment="Center"

                                        Orientation="Horizontal"

                                        Spacing="5">

                                        <Button

                                            Width="180"

                                            Height="40"

                                            Click="OperatingGuideWindowIcon_Click"

                                            FontWeight="Bold">

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Orientation="Horizontal"

                                                Spacing="0">

                                                <ui:FontIcon

                                                    Margin="0,1,4,0"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource PopupWindowForeground}"

                                                    Glyph="&#xe82d;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    FontSize="15"

                                                    FontWeight="Bold">

                                                    指南

                                                </Label>

                                            </ikw:SimpleStackPanel>

                                        </Button>

                                        <Button

                                            Width="180"

                                            Height="40"

                                            Click="BtnOpenInitialSetup_Click"

                                            FontWeight="Bold">

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Orientation="Horizontal"

                                                Spacing="0">

                                                <ui:FontIcon

                                                    Margin="0,1,4,0"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource PopupWindowForeground}"

                                                    Glyph="&#xE7C3;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    FontSize="15"

                                                    FontWeight="Bold">

                                                    重新查看引导

                                                </Label>

                                            </ikw:SimpleStackPanel>

                                        </Button>

                                    </ikw:SimpleStackPanel>

                                </ikw:SimpleStackPanel>

                            </ikw:SimpleStackPanel>

                        </Border>

                        <GroupBox x:Name="SettingsSection_Startup">

                            <GroupBox.Header>

                                <TextBlock

                                    FontSize="26"

                                    FontWeight="Bold"

                                    Foreground="{DynamicResource PopupWindowForeground}"

                                    Text="启动选项" />

                            </GroupBox.Header>

                            <ikw:SimpleStackPanel Spacing="5">

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchIsAutoUpdate"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchIsAutoUpdate_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="自动检查更新" />

                                </ikw:SimpleStackPanel>

                                <Border

                                    Padding="12"

                                    BorderBrush="{DynamicResource PopupWindowBorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="5">

                                    <ikw:SimpleStackPanel Spacing="12">

                                        <TextBlock

                                            Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                                            Text="# 开启 自动检查更新 后，将在软件启动时检查版本号，若版本号落后则会尝试从 Github 下载最新版安装包，安装新版本后会自动删除安装包。更新代理设置文本框放空即为直接裸连 Github。"

                                            TextWrapping="Wrap" />

                                        <ikw:SimpleStackPanel Orientation="Horizontal">

                                            <ikw:SimpleStackPanel Width="50">

                                                <ui:ToggleSwitch

                                                    Name="ToggleSwitchIsAutoUpdateWithProxy"

                                                    OffContent="关"

                                                    OnContent="开"

                                                    Toggled="ToggleSwitchIsAutoUpdateWithProxy_Toggled" />

                                            </ikw:SimpleStackPanel>

                                            <TextBlock

                                                Margin="0,0,14,0"

                                                VerticalAlignment="Center"

                                                FontSize="14"

                                                Foreground="{DynamicResource PopupWindowForeground}"

                                                Text="代理设置" />

                                        </ikw:SimpleStackPanel>

                                        <TextBlock

                                            x:Name="AutoUpdateWithProxy_Title"

                                            FontSize="15"

                                            FontWeight="Bold"

                                            Foreground="{DynamicResource PopupWindowForeground}"

                                            Text="更新代理设置"

                                            TextWrapping="Wrap" />

                                        <TextBox

                                            x:Name="AutoUpdateProxyTextBox"

                                            Text="https://ghproxy.net/"

                                            TextChanged="AutoUpdateProxyTextBox_TextChanged"

                                            TextWrapping="Wrap"

                                            Visibility="{Binding ElementName=AutoUpdateWithProxy_Title, Path=Visibility}" />

                                        <Grid Visibility="{Binding ElementName=AutoUpdateWithProxy_Title, Path=Visibility}">

                                            <Grid.ColumnDefinitions>

                                                <ColumnDefinition Width="Auto" />

                                                <ColumnDefinition Width="*" />

                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal">

                                                <Button

                                                    Padding="15,7.5"

                                                    Click="BtnResetAutoUpdateProxyToGHProxy_Click"

                                                    Content="设置Github默认代理" />

                                            </StackPanel>

                                            <StackPanel

                                                Grid.Column="1"

                                                HorizontalAlignment="Right"

                                                Orientation="Horizontal">

                                                <Button

                                                    Padding="15,7.5"

                                                    Click="BtnCheckAutoUpdateProxyReturnedData_Click"

                                                    Content="检查代理返回数据" />

                                            </StackPanel>

                                        </Grid>

                                        <TextBlock

                                            Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                                            Text="# 正确的代理返回数据应为三位版本号，例如 &quot;4.0.0&quot;。"

                                            TextWrapping="Wrap"

                                            Visibility="{Binding ElementName=AutoUpdateWithProxy_Title, Path=Visibility}" />

                                        <TextBlock

                                            Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                                            Text="# 检查代理返回数据具有一定延迟，弹窗内容为空即无返回数据。"

                                            TextWrapping="Wrap"

                                            Visibility="{Binding ElementName=AutoUpdateWithProxy_Title, Path=Visibility}" />

                                    </ikw:SimpleStackPanel>

                                </Border>

                                <ikw:SimpleStackPanel x:Name="IsAutoUpdateWithSilenceBlock" Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchIsAutoUpdateWithSilence"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchIsAutoUpdateWithSilence_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="静默更新" />

                                </ikw:SimpleStackPanel>

                                <Border

                                    Padding="12"

                                    BorderBrush="{DynamicResource PopupWindowBorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="5"

                                    Visibility="{Binding ElementName=IsAutoUpdateWithSilenceBlock, Path=Visibility}">

                                    <ikw:SimpleStackPanel Spacing="12">

                                        <TextBlock

                                            Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                                            Text="# 关闭静默更新后，已完成安装包的下载后将会弹窗询问是否进行更新，开启静默更新后将会在安装包下载完成后每隔十分钟进行如下检测：①处于静默更新时间段内 ②未处于书写模式 ③未处于画板内。若以上检测通过即会关闭软件进行自动更新。"

                                            TextWrapping="Wrap" />

                                        <ikw:SimpleStackPanel x:Name="AutoUpdateTimePeriodBlock" Spacing="12">

                                            <ikw:SimpleStackPanel Spacing="12">

                                                <TextBlock

                                                    FontSize="15"

                                                    FontWeight="Bold"

                                                    Foreground="{DynamicResource PopupWindowForeground}"

                                                    Text="静默更新时间段"

                                                    TextWrapping="Wrap" />

                                                <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="12">

                                                    <ikw:SimpleStackPanel Orientation="Horizontal">

                                                        <TextBlock

                                                            Margin="0,0,10,0"

                                                            VerticalAlignment="Center"

                                                            FontSize="14"

                                                            Foreground="{DynamicResource PopupWindowForeground}"

                                                            Text="起始时间"

                                                            TextWrapping="Wrap" />

                                                        <ComboBox

                                                            x:Name="AutoUpdateWithSilenceStartTimeComboBox"

                                                            Width="90"

                                                            SelectionChanged="AutoUpdateWithSilenceStartTimeComboBox_SelectionChanged" />

                                                    </ikw:SimpleStackPanel>

                                                    <ikw:SimpleStackPanel Orientation="Horizontal">

                                                        <TextBlock

                                                            Margin="0,0,10,0"

                                                            VerticalAlignment="Center"

                                                            FontSize="14"

                                                            Foreground="{DynamicResource PopupWindowForeground}"

                                                            Text="终止时间"

                                                            TextWrapping="Wrap" />

                                                        <ComboBox

                                                            x:Name="AutoUpdateWithSilenceEndTimeComboBox"

                                                            Width="90"

                                                            SelectionChanged="AutoUpdateWithSilenceEndTimeComboBox_SelectionChanged" />

                                                    </ikw:SimpleStackPanel>

                                                </ikw:SimpleStackPanel>

                                                <TextBlock

                                                    Width="340"

                                                    Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                                                    Text="# 若终止时间小于起始时间，即将终止时间视为第二天的时间。# 若起始时间与终止时间相同，即视为全天候时间。"

                                                    TextWrapping="Wrap" />

                                            </ikw:SimpleStackPanel>

                                        </ikw:SimpleStackPanel>

                                    </ikw:SimpleStackPanel>

                                </Border>

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchRunAtStartup"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchRunAtStartup_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="开机时运行" />

                                </ikw:SimpleStackPanel>

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchFoldAtStartup"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchFoldAtStartup_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="开机运行后收纳到侧边栏" />

                                </ikw:SimpleStackPanel>

                            </ikw:SimpleStackPanel>

                        </GroupBox>

                        <GroupBox x:Name="SettingsSection_Board">

                            <GroupBox.Header>

                                <TextBlock

                                    FontSize="26"

                                    FontWeight="Bold"

                                    Foreground="{DynamicResource PopupWindowForeground}"

                                    Text="画板选项" />

                            </GroupBox.Header>

                            <ikw:SimpleStackPanel Spacing="5">

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchCompressPicturesUploaded"

                                            IsOn="False"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchCompressPicturesUploaded_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="上传图片时将画质压缩至 1080P 及以下" />

                                </ikw:SimpleStackPanel>

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchShowCursor"

                                            IsOn="False"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchShowCursor_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="显示画笔光标" />

                                </ikw:SimpleStackPanel>

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <TextBlock

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="橡皮大小：" />

                                    <ComboBox

                                        Name="ComboBoxEraserSize"

                                        Margin="5,0,0,0"

                                        SelectedIndex="2"

                                        SelectionChanged="ComboBoxEraserSize_SelectionChanged">

                                        <ComboBoxItem Content="小" />

                                        <ComboBoxItem Content="较小" />

                                        <ComboBoxItem Content="中（默认）" />

                                        <ComboBoxItem Content="较大" />

                                        <ComboBoxItem Content="大" />

                                    </ComboBox>

                                </ikw:SimpleStackPanel>

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchHideStrokeWhenSelecting"

                                            IsOn="False"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchHideStrokeWhenSelecting_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="退出画板模式后隐藏墨迹" />

                                </ikw:SimpleStackPanel>

                                <TextBlock

                                    Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                                    Text="# 开启 退出画板模式后隐藏墨迹 选项后，进入 PPT 模式时未处于批注模式时不会显示墨迹。"

                                    TextWrapping="Wrap" />

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <TextBlock

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="保留双曲线渐近线：  " />

                                    <ComboBox

                                        Name="ComboBoxHyperbolaAsymptoteOption"

                                        SelectedIndex="0"

                                        SelectionChanged="ComboBoxHyperbolaAsymptoteOption_SelectionChanged">

                                        <ComboBoxItem Content="是" />

                                        <ComboBoxItem Content="否" />

                                        <ComboBoxItem Content="每次询问" />

                                    </ComboBox>

                                </ikw:SimpleStackPanel>

                                <TextBlock

                                    Foreground="{DynamicResource SettingsPageAnnotationForeground}"

                                    Text="# 请注意，若不保留双曲线渐近线可能会有遇到撤回相关的 BUG 影响用。"

                                    TextWrapping="Wrap" />

                            </ikw:SimpleStackPanel>

                        </GroupBox>

                        <GroupBox x:Name="SettingsSection_Gesture">

                            <GroupBox.Header>

                                <TextBlock

                                    FontSize="26"

                                    FontWeight="Bold"

                                    Foreground="{DynamicResource PopupWindowForeground}"

                                    Text="手势选项" />

                            </GroupBox.Header>

                            <ikw:SimpleStackPanel Spacing="5">

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <TextBlock

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="缩放/旋转变换中心点：" />

                                    <ComboBox

                                        Name="ComboBoxMatrixTransformCenterPoint"

                                        Width="180"

                                        Margin="5,0,0,0"

                                        SelectedIndex="0"

                                        SelectionChanged="ComboBoxMatrixTransformCenterPoint_SelectionChanged">

                                        <ComboBoxItem Content="画布中心点（默认）" />

                                        <ComboBoxItem Content="全部内容的中心点" />

                                        <ComboBoxItem Content="手势操作的中心点" />

                                    </ComboBox>

                                </ikw:SimpleStackPanel>

                                <ikw:SimpleStackPanel Orientation="Horizontal">

                                    <ikw:SimpleStackPanel Width="50">

                                        <ui:ToggleSwitch

                                            Name="ToggleSwitchAutoSwitchTwoFingerGesture"

                                            IsOn="True"

                                            OffContent="关"

                                            OnContent="开"

                                            Toggled="ToggleSwitchAutoSwitchTwoFingerGesture_Toggled" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        Margin="0,0,14,0"

                                        VerticalAlignment="Center"

                                        FontSize="14"

                                        Foreground="{DynamicResource PopupWindowForeground}"

                                        Text="自动开关两指缩放功能" />

                                </ikw:SimpleStackPanel>

                                <TextBlock

                                    Foreground="{DynamicResource SettingsPageAnnotationForeground}"

