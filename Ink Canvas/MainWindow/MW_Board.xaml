<UserControl
    x:Class="Ink_Canvas.MW_Board"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:Ink_Canvas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    mc:Ignorable="d">
    <Grid>
        <!--  // 画板界面 //  -->

        <Grid>

            <!--  左下角  -->

            <Viewbox

                x:Name="ViewboxBlackboardLeftSide"

                Height="55"

                Margin="3,0,0,0"

                HorizontalAlignment="Left"

                VerticalAlignment="Bottom">

                <Viewbox.LayoutTransform>

                    <ScaleTransform x:Name="ViewboxBlackboardLeftSideScaleTransform" ScaleX="1" ScaleY="1" />

                </Viewbox.LayoutTransform>

                <Grid

                    x:Name="BlackboardLeftSide"

                    Height="55"

                    Margin="3,0,0,0"

                    HorizontalAlignment="Left"

                    VerticalAlignment="Bottom"

                    Opacity="0.75"

                    Visibility="Visible">

                    <Grid.Resources>

                        <!--  定义 SolidColorBrush 资源  -->

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundKey}" Color="{DynamicResource BoardBarButtonBackgroundKey}" />

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}" Color="{DynamicResource BoardBarButtonBackgroundPointerOverKey}" />

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}" Color="{DynamicResource BoardBarButtonButtonBackgroundPressedKey}" />

                        <!--  定义按钮样式  -->

                        <Style TargetType="Button">

                            <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundKey}}" />

                            <Setter Property="Template">

                                <Setter.Value>

                                    <ControlTemplate TargetType="Button">

                                        <Border

                                            Background="{TemplateBinding Background}"

                                            BorderBrush="{TemplateBinding BorderBrush}"

                                            BorderThickness="{TemplateBinding BorderThickness}"

                                            CornerRadius="5">

                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        </Border>

                                        <ControlTemplate.Triggers>

                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}}" />

                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">

                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}}" />

                                            </Trigger>

                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>

                                </Setter.Value>

                            </Setter>

                        </Style>

                    </Grid.Resources>

                    <ikw:SimpleStackPanel Orientation="Horizontal">

                        <Button

                            x:Name="BtnWhiteBoardSwitchPrevious"

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="BtnWhiteBoardSwitchPrevious_Click"

                            IsEnabledChanged="Element_IsEnabledChanged">

                            <Border

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="1,1,0.25,1"

                                CornerRadius="5,0,0,5">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xe760;" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="上一页" />

                                </Grid>

                            </Border>

                        </Button>

                        <Border

                            Width="58"

                            Height="55"

                            Background="{DynamicResource BoardBarBackground}"

                            BorderBrush="{DynamicResource BoardBarBorderBrush}"

                            BorderThickness="0,1,0.25,1">

                            <Grid Margin="0,5">

                                <ikw:SimpleStackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                                    <TextBlock

                                        Name="TextBlockWhiteBoardIndexInfo"

                                        Margin="0,4,0,2"

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Center"

                                        FontSize="15"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="1 / 1" />

                                    <TextBlock

                                        Margin="0,3,0,0"

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Center"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="页码" />

                                </ikw:SimpleStackPanel>

                            </Grid>

                        </Border>

                        <Button

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="BtnWhiteBoardSwitchNext_Click"

                            IsEnabledChanged="Element_IsEnabledChanged">

                            <Border

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="0,1,1,1"

                                CornerRadius="0,5,5,0">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        x:Name="BoardLeftPannelNextPage1"

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xecc8;"

                                        IsEnabled="True"

                                        IsEnabledChanged="Element_IsEnabledChanged" />

                                    <ui:FontIcon

                                        x:Name="BoardLeftPannelNextPage2"

                                        Width="0"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xe761;"

                                        Opacity="{Binding ElementName=BoardLeftPannelNextPage1, Path=Opacity}" />

                                    <TextBlock

                                        x:Name="BoardLeftPannelNextPageTextBlock"

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Opacity="{Binding ElementName=BoardLeftPannelNextPage1, Path=Opacity}"

                                        Text="加页" />

                                </Grid>

                            </Border>

                        </Button>

                        <Button

                            Width="55"

                            Height="55"

                            Margin="5,0,0,0"

                            Padding="0"

                            BorderThickness="0"

                            Click="ImageBlackboard_Click">

                            <Border

                                Width="55"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="1"

                                CornerRadius="5">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xe944;" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="退出" />

                                </Grid>

                            </Border>

                        </Button>

                    </ikw:SimpleStackPanel>

                </Grid>

            </Viewbox>

            <!--  中间  -->

            <Viewbox

                x:Name="ViewboxBlackboardCenterSide"

                Height="55"

                Margin="3,0,0,0"

                HorizontalAlignment="Center"

                VerticalAlignment="Bottom">

                <Viewbox.LayoutTransform>

                    <ScaleTransform x:Name="ViewboxBlackboardCenterSideScaleTransform" ScaleX="1" ScaleY="1" />

                </Viewbox.LayoutTransform>

                <Grid

                    x:Name="BlackboardCenterSide"

                    Height="55"

                    HorizontalAlignment="Center"

                    VerticalAlignment="Bottom"

                    Visibility="Visible">

                    <Grid.Resources>

                        <!--  定义 SolidColorBrush 资源  -->

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundKey}" Color="{DynamicResource BoardBarButtonBackgroundKey}" />

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}" Color="{DynamicResource BoardBarButtonBackgroundPointerOverKey}" />

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}" Color="{DynamicResource BoardBarButtonButtonBackgroundPressedKey}" />

                        <!--  定义按钮样式  -->

                        <Style TargetType="Button">

                            <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundKey}}" />

                            <Setter Property="Template">

                                <Setter.Value>

                                    <ControlTemplate TargetType="Button">

                                        <Border

                                            Background="{TemplateBinding Background}"

                                            BorderBrush="{TemplateBinding BorderBrush}"

                                            BorderThickness="{TemplateBinding BorderThickness}"

                                            CornerRadius="5">

                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        </Border>

                                        <ControlTemplate.Triggers>

                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}}" />

                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">

                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}}" />

                                            </Trigger>

                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>

                                </Setter.Value>

                            </Setter>

                        </Style>

                    </Grid.Resources>

                    <ikw:SimpleStackPanel Orientation="Horizontal">



                        <Button

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="TwoFingerGestureBorder_Click">

                            <Border

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="1,1,0.25,1"

                                CornerRadius="5,0,0,5">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="28"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xf271;"

                                        Opacity="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FloatBarHostBridge.EnableTwoFingerGestureBtnBridge.Opacity}" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="手势" />

                                </Grid>

                            </Border>

                        </Button>

                        <Grid Width="0" Margin="0,0,0,5">

                            <Viewbox

                                Name="BoardTwoFingerGestureBorder"

                                Height="173"

                                Margin="-119,-177,-71,0"

                                VerticalAlignment="Top"

                                Visibility="Visible">

                                <Border

                                    Width="149"

                                    Height="135"

                                    Background="{DynamicResource BoardBarBackground}"

                                    BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="5">

                                    <ikw:SimpleStackPanel>

                                        <Border

                                            Margin="-1,-1,-1,0"

                                            Padding="15,5"

                                            Background="{DynamicResource BoardBarTitleBackground}"

                                            BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                            BorderThickness="1"

                                            CornerRadius="5,5,0,0">

                                            <TextBlock

                                                FontSize="11"

                                                FontWeight="Bold"

                                                Foreground="{DynamicResource BoardBarForeground}"

                                                Text="手势功能"

                                                TextAlignment="Left" />

                                        </Border>

                                        <ikw:SimpleStackPanel Margin="10,4,10,0" Spacing="-2.5">

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Orientation="Horizontal"

                                                Spacing="8">

                                                <ui:FontIcon

                                                    Width="20"

                                                    Height="20"

                                                    Margin="0,4,0,2"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource BoardBarForeground}"

                                                    Glyph="&#xe716;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    Content="多指书写"

                                                    FontSize="12"

                                                    Foreground="{DynamicResource BoardBarForeground}" />

                                                <Viewbox Width="36" Height="25">

                                                    <ui:ToggleSwitch

                                                        Name="BoardToggleSwitchEnableMultiTouchMode"

                                                        Width="42"

                                                        MinWidth="0"

                                                        ui:ThemeManager.RequestedTheme="{DynamicResource BoardTheme}"

                                                        IsOn="False"

                                                        OffContent=""

                                                        OnContent=""

                                                        Toggled="ToggleSwitchEnableMultiTouchMode_Toggled" />

                                                </Viewbox>

                                            </ikw:SimpleStackPanel>

                                            <ikw:SimpleStackPanel

                                                x:Name="BoardTwoFingerGestureSimpleStackPanel"

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Opacity="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FloatBarHostBridge.TwoFingerGestureSimpleStackPanelBridge.Opacity}"

                                                Orientation="Horizontal"

                                                Spacing="8">

                                                <ui:FontIcon

                                                    Width="20"

                                                    Height="20"

                                                    Margin="0,4,0,2"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource BoardBarForeground}"

                                                    Glyph="&#xe7c2;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    Content="双指移动"

                                                    FontSize="12"

                                                    Foreground="{DynamicResource BoardBarForeground}" />

                                                <Viewbox Width="36" Height="25">

                                                    <ui:ToggleSwitch

                                                        Name="BoardToggleSwitchEnableTwoFingerTranslate"

                                                        Width="42"

                                                        MinWidth="0"

                                                        ui:ThemeManager.RequestedTheme="{DynamicResource BoardTheme}"

                                                        IsOn="False"

                                                        OffContent=""

                                                        OnContent=""

                                                        Toggled="ToggleSwitchEnableTwoFingerTranslate_Toggled" />

                                                </Viewbox>

                                            </ikw:SimpleStackPanel>

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Opacity="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FloatBarHostBridge.TwoFingerGestureSimpleStackPanelBridge.Opacity}"

                                                Orientation="Horizontal"

                                                Spacing="8">

                                                <ui:FontIcon

                                                    Width="20"

                                                    Height="20"

                                                    Margin="0,4,0,2"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource BoardBarForeground}"

                                                    Glyph="&#xe740;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    Content="双指缩放"

                                                    FontSize="12"

                                                    Foreground="{DynamicResource BoardBarForeground}" />

                                                <Viewbox Width="36" Height="25">

                                                    <ui:ToggleSwitch

                                                        Name="BoardToggleSwitchEnableTwoFingerZoom"

                                                        Width="42"

                                                        MinWidth="0"

                                                        ui:ThemeManager.RequestedTheme="{DynamicResource BoardTheme}"

                                                        IsOn="False"

                                                        OffContent=""

                                                        OnContent=""

                                                        Toggled="ToggleSwitchEnableTwoFingerZoom_Toggled" />

                                                </Viewbox>

                                            </ikw:SimpleStackPanel>

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Opacity="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FloatBarHostBridge.TwoFingerGestureSimpleStackPanelBridge.Opacity}"

                                                Orientation="Horizontal"

                                                Spacing="8">

                                                <ui:FontIcon

                                                    Width="20"

                                                    Height="20"

                                                    Margin="0,4,0,2"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource BoardBarForeground}"

                                                    Glyph="&#xe7ad;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    Content="双指旋转"

                                                    FontSize="12"

                                                    Foreground="{DynamicResource BoardBarForeground}" />

                                                <Viewbox Width="36" Height="25">

                                                    <ui:ToggleSwitch

                                                        Name="BoardToggleSwitchEnableTwoFingerRotation"

                                                        Width="42"

                                                        MinWidth="0"

                                                        ui:ThemeManager.RequestedTheme="{DynamicResource BoardTheme}"

                                                        OffContent=""

                                                        OnContent=""

                                                        Toggled="ToggleSwitchEnableTwoFingerRotation_Toggled" />

                                                </Viewbox>

                                            </ikw:SimpleStackPanel>

                                        </ikw:SimpleStackPanel>

                                    </ikw:SimpleStackPanel>

                                </Border>

                            </Viewbox>

                        </Grid>

                        <Button

                            Width="60"

                            Height="55"

                            Margin="0,0,5,0"

                            Padding="0"

                            BorderThickness="0"

                            Click="BoardChangeBackgroundColorBtn_Click"

                            PreviewMouseRightButtonDown="BoardCanvasBtn_PreviewMouseRightButtonDown"

                            PreviewTouchDown="BoardCanvasBtn_PreviewTouchDown"

                            PreviewTouchUp="BoardCanvasBtn_PreviewTouchUp">

                            <Border

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="0,1,1,1"

                                CornerRadius="0,5,5,0">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="22"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xef1f;" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="画布" />

                                </Grid>

                            </Border>

                        </Button>

                        <!-- 画布右键弹出：方格纸开关 -->
                        <Grid Width="0" Margin="0,0,0,5">

                            <Viewbox

                                Name="BoardGridPaperBorder"

                                Height="200"

                                Margin="-119,-204,-71,0"

                                VerticalAlignment="Top"

                                Visibility="Collapsed">

                                <Border

                                    Width="149"

                                    Height="165"

                                    Background="{DynamicResource BoardBarBackground}"

                                    BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="5">

                                    <ikw:SimpleStackPanel>

                                        <Border

                                            Margin="-1,-1,-1,0"

                                            Padding="15,5"

                                            Background="{DynamicResource BoardBarTitleBackground}"

                                            BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                            BorderThickness="1"

                                            CornerRadius="5,5,0,0">

                                            <TextBlock

                                                FontSize="11"

                                                FontWeight="Bold"

                                                Foreground="{DynamicResource BoardBarForeground}"

                                                Text="方格纸"

                                                TextAlignment="Left" />

                                        </Border>

                                        <ikw:SimpleStackPanel Margin="10,4,10,0" Spacing="-2.5">

                                            <ikw:SimpleStackPanel

                                                HorizontalAlignment="Center"

                                                VerticalAlignment="Center"

                                                Orientation="Horizontal"

                                                Spacing="8">

                                                <ui:FontIcon

                                                    Width="20"

                                                    Height="20"

                                                    Margin="0,4,0,2"

                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                    FontSize="16"

                                                    Foreground="{DynamicResource BoardBarForeground}"

                                                    Glyph="&#xe80a;" />

                                                <Label

                                                    VerticalAlignment="Center"

                                                    Content="显示方格"

                                                    FontSize="12"

                                                    Foreground="{DynamicResource BoardBarForeground}" />

                                                <Viewbox Width="36" Height="25">

                                                    <ui:ToggleSwitch

                                                        Name="BoardToggleSwitchGridPaper"

                                                        Width="42"

                                                        MinWidth="0"

                                                        ui:ThemeManager.RequestedTheme="{DynamicResource BoardTheme}"

                                                        IsOn="False"

                                                        OffContent=""

                                                        OnContent=""

                                                        Toggled="ToggleSwitchGridPaper_Toggled" />

                                                </Viewbox>

                                            </ikw:SimpleStackPanel>

                                            <ikw:SimpleStackPanel Margin="0,2,0,0">

                                                <TextBlock

                                                    FontSize="10"

                                                    Foreground="{DynamicResource BoardBarForeground}"

                                                    Text="水平间距"

                                                    Margin="0,0,0,2" />

                                                <Grid>

                                                    <Grid.ColumnDefinitions>

                                                        <ColumnDefinition Width="*" />

                                                        <ColumnDefinition Width="Auto" />

                                                    </Grid.ColumnDefinitions>

                                                    <Slider

                                                        Name="BoardGridSpacingXSlider"

                                                        Grid.Column="0"

                                                        ui:ThemeManager.RequestedTheme="{DynamicResource BoardTheme}"

                                                        IsSnapToTickEnabled="True"

                                                        Maximum="80"

                                                        Minimum="10"

                                                        TickFrequency="5"

                                                        TickPlacement="None"

                                                        ValueChanged="GridSpacingXSlider_ValueChanged"

                                                        Value="30" />

                                                    <TextBlock

                                                        Grid.Column="1"

                                                        Margin="6,0,0,0"

                                                        VerticalAlignment="Center"

                                                        FontSize="10"

                                                        Foreground="{DynamicResource BoardBarForeground}"

                                                        Text="{Binding ElementName=BoardGridSpacingXSlider, Path=Value, Mode=OneWay}" />

                                                </Grid>

                                                <TextBlock

                                                    FontSize="10"

                                                    Foreground="{DynamicResource BoardBarForeground}"

                                                    Text="垂直间距"

                                                    Margin="0,4,0,2" />

                                                <Grid>

                                                    <Grid.ColumnDefinitions>

                                                        <ColumnDefinition Width="*" />

                                                        <ColumnDefinition Width="Auto" />

                                                    </Grid.ColumnDefinitions>

                                                    <Slider

                                                        Name="BoardGridSpacingYSlider"

                                                        Grid.Column="0"

                                                        ui:ThemeManager.RequestedTheme="{DynamicResource BoardTheme}"

                                                        IsSnapToTickEnabled="True"

                                                        Maximum="80"

                                                        Minimum="10"

                                                        TickFrequency="5"

                                                        TickPlacement="None"

                                                        ValueChanged="GridSpacingYSlider_ValueChanged"

                                                        Value="30" />

                                                    <TextBlock

                                                        Grid.Column="1"

                                                        Margin="6,0,0,0"

                                                        VerticalAlignment="Center"

                                                        FontSize="10"

                                                        Foreground="{DynamicResource BoardBarForeground}"

                                                        Text="{Binding ElementName=BoardGridSpacingYSlider, Path=Value, Mode=OneWay}" />

                                                </Grid>

                                            </ikw:SimpleStackPanel>

                                        </ikw:SimpleStackPanel>

                                    </ikw:SimpleStackPanel>

                                </Border>

                            </Viewbox>

                        </Grid>

                        <Button

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="BoardSelectIcon_Click">

                            <Border

                                x:Name="BoardSelect"

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="1,1,0.25,1"

                                CornerRadius="5,0,0,5">

                                <Grid Margin="5">

                                    <ikw:SimpleStackPanel

                                        Width="28"

                                        Height="28"

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Top"

                                        Background="Transparent"

                                        Orientation="Horizontal">

                                        <ui:FontIcon

                                            Width="28"

                                            Height="22"

                                            FontFamily="{StaticResource FluentIconFontFamily}"

                                            FontSize="22"

                                            Foreground="{DynamicResource BoardBarForeground}"

                                            Glyph="&#xe958;" />

                                        <ui:FontIcon

                                            Width="10"

                                            Height="22"

                                            Margin="-24,0,0,-13"

                                            FontFamily="{StaticResource FluentIconFontFamily}"

                                            FontSize="14"

                                            Foreground="{DynamicResource BoardBarForeground}"

                                            Glyph="&#xf8af;" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="选择" />

                                </Grid>

                            </Border>

                        </Button>

                        <Button

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="BoardPenIcon_Click">

                            <Border

                                x:Name="BoardPen"

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="0,1,0.25,1">

                                <Grid Margin="5">

                                    <ikw:SimpleStackPanel

                                        x:Name="BoardPenIcon"

                                        Width="28"

                                        Height="28"

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Top"

                                        Background="Transparent"

                                        Orientation="Horizontal">

                                        <ui:FontIcon

                                            Width="28"

                                            Height="22"

                                            FontFamily="{StaticResource FluentIconFontFamily}"

                                            FontSize="22"

                                            Foreground="{DynamicResource BoardBarForeground}"

                                            Glyph="&#xee56;" />

                                    </ikw:SimpleStackPanel>

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="墨迹" />

                                </Grid>

                            </Border>

                        </Button>

                        <Border>

                            <Grid Width="0">

                                <Border

                                    x:Name="BoardPenPalette"

                                    Margin="-248,-218,-190,59"

                                    Background="{DynamicResource BoardBarBackground}"

                                    BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="5"

                                    Visibility="Visible">

                                    <ikw:SimpleStackPanel>

                                        <Border

                                            Margin="-1,-1,-1,0"

                                            Padding="15,5"

