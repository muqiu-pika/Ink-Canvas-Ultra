                                                        Spacing="5">

                                                        <Image

                                                            Width="22"

                                                            Height="22"

                                                            RenderOptions.BitmapScalingMode="HighQuality"

                                                            Source="/Resources/Icons-png/Desmos.png">

                                                            <Image.Clip>

                                                                <EllipseGeometry

                                                                    Center="11,11"

                                                                    RadiusX="11"

                                                                    RadiusY="11" />

                                                            </Image.Clip>

                                                        </Image>

                                                        <TextBlock

                                                            VerticalAlignment="Center"

                                                            FontSize="12.5"

                                                            Foreground="{DynamicResource BoardBarForeground}"

                                                            Text="Desmos" />

                                                    </ikw:SimpleStackPanel>

                                                </Button>

                                            </ikw:SimpleStackPanel>

                                        </Border>

                                    </ikw:SimpleStackPanel>

                                </Border>

                            </Grid>

                        </Border>

                        <Button

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="ImageBlackboard_Click">

                            <Border

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="0,1,1,1"

                                CornerRadius="0,5,5,0">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xe944;" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="退出" />

                                </Grid>

                            </Border>

                        </Button>

                    </ikw:SimpleStackPanel>

                </Grid>

            </Viewbox>

            <!--  右下角  -->

            <Viewbox

                x:Name="ViewboxBlackboardRightSide"

                Height="55"

                Margin="3,0,0,0"

                HorizontalAlignment="Right"

                VerticalAlignment="Bottom">

                <Viewbox.LayoutTransform>

                    <ScaleTransform x:Name="ViewboxBlackboardRightSideScaleTransform" ScaleX="1" ScaleY="1" />

                </Viewbox.LayoutTransform>

                <Grid

                    x:Name="BlackboardRightSide"

                    Height="55"

                    Margin="0,0,3,0"

                    HorizontalAlignment="Right"

                    VerticalAlignment="Bottom"

                    Opacity="0.75"

                    Visibility="Visible">

                    <Grid.Resources>

                        <!--  定义 SolidColorBrush 资源  -->

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundKey}" Color="{DynamicResource BoardBarButtonBackgroundKey}" />

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}" Color="{DynamicResource BoardBarButtonBackgroundPointerOverKey}" />

                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}" Color="{DynamicResource BoardBarButtonButtonBackgroundPressedKey}" />

                        <!--  定义按钮样式  -->

                        <Style TargetType="Button">

                            <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundKey}}" />

                            <Setter Property="Template">

                                <Setter.Value>

                                    <ControlTemplate TargetType="Button">

                                        <Border

                                            Background="{TemplateBinding Background}"

                                            BorderBrush="{TemplateBinding BorderBrush}"

                                            BorderThickness="{TemplateBinding BorderThickness}"

                                            CornerRadius="5">

                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />

                                        </Border>

                                        <ControlTemplate.Triggers>

                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}}" />

                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">

                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}}" />

                                            </Trigger>

                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>

                                </Setter.Value>

                            </Setter>

                        </Style>

                    </Grid.Resources>

                    <ikw:SimpleStackPanel Orientation="Horizontal">

                        <Button

                            Width="55"

                            Height="55"

                            Margin="0,0,5,0"

                            Padding="0"

                            BorderThickness="0"

                            Click="BtnWhiteBoardAdd_Click">

                            <Border

                                Width="55"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="1"

                                CornerRadius="3">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        x:Name="BtnBoardAddPage"

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xecc8;"

                                        IsEnabled="True"

                                        IsEnabledChanged="Element_IsEnabledChanged" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Opacity="{Binding ElementName=BtnBoardAddPage, Path=Opacity}"

                                        Text="加页" />

                                </Grid>

                            </Border>

                        </Button>



                        <Button

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="BtnWhiteBoardSwitchPrevious_Click"

                            IsEnabled="{Binding ElementName=BtnWhiteBoardSwitchPrevious, Path=IsEnabled}"

                            Opacity="{Binding ElementName=BtnWhiteBoardSwitchPrevious, Path=Opacity}">

                            <Border

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="1,1,0.25,1"

                                CornerRadius="3,0,0,3">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        Width="26"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xe760;" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="上一页" />

                                </Grid>

                            </Border>

                        </Button>

                        <Border

                            Width="58"

                            Height="55"

                            Background="{DynamicResource BoardBarBackground}"

                            BorderBrush="{DynamicResource BoardBarBorderBrush}"

                            BorderThickness="0,1,0.25,1">

                            <Grid Margin="0,5">

                                <ikw:SimpleStackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                                    <TextBlock

                                        Margin="0,4,0,2"

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Center"

                                        FontSize="15"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="{Binding ElementName=TextBlockWhiteBoardIndexInfo, Path=Text}" />

                                    <TextBlock

                                        Margin="0,3,0,0"

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Center"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Text="页码" />

                                </ikw:SimpleStackPanel>

                            </Grid>

                        </Border>



                        <Button

                            Width="60"

                            Height="55"

                            Padding="0"

                            BorderThickness="0"

                            Click="BtnWhiteBoardSwitchNext_Click">

                            <Border

                                Width="60"

                                Height="55"

                                Background="{DynamicResource BoardBarBackground}"

                                BorderBrush="{DynamicResource BoardBarBorderBrush}"

                                BorderThickness="0,1,1,1"

                                CornerRadius="0,5,5,0">

                                <Grid Margin="5">

                                    <ui:FontIcon

                                        Width="{Binding ElementName=BoardLeftPannelNextPage1, Path=Width}"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xecc8;"

                                        Opacity="{Binding ElementName=BoardLeftPannelNextPage1, Path=Opacity}" />

                                    <ui:FontIcon

                                        Width="{Binding ElementName=BoardLeftPannelNextPage2, Path=Width}"

                                        Height="26"

                                        VerticalAlignment="Top"

                                        FontFamily="{StaticResource FluentIconFontFamily}"

                                        FontSize="24"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Glyph="&#xe761;"

                                        Opacity="{Binding ElementName=BoardLeftPannelNextPage1, Path=Opacity}" />

                                    <TextBlock

                                        HorizontalAlignment="Center"

                                        VerticalAlignment="Bottom"

                                        FontSize="12"

                                        Foreground="{DynamicResource BoardBarForeground}"

                                        Opacity="{Binding ElementName=BoardLeftPannelNextPage1, Path=Opacity}"

                                        Text="{Binding ElementName=BoardLeftPannelNextPageTextBlock, Path=Text}" />

                                </Grid>

                            </Border>

                        </Button>

                    </ikw:SimpleStackPanel>

                </Grid>

            </Viewbox>

        </Grid>
    </Grid>
</UserControl>

