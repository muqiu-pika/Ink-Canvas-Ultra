<UserControl
    x:Class="Ink_Canvas.MW_FloatBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:Ink_Canvas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    mc:Ignorable="d">
    <Grid>
        <!--  // 浮动批注主窗口 //  -->

        <Viewbox

            Name="ViewboxFloatingBar"

            Height="50"

            Margin="100,0,-2000,-200"

            HorizontalAlignment="Left"

            VerticalAlignment="Top">

            <Viewbox.LayoutTransform>

                <ScaleTransform x:Name="ViewboxFloatingBarScaleTransform" ScaleX="1" ScaleY="1" />

            </Viewbox.LayoutTransform>

            <ikw:SimpleStackPanel Orientation="Horizontal">



                <ikw:SimpleStackPanel.Resources>
                    <ResourceDictionary>
                        <!--  定义 SolidColorBrush 资源  -->
                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundKey}" Color="{DynamicResource FloatBarButtonBackgroundKey}" />
                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}" Color="{DynamicResource FloatBarButtonBackgroundPointerOverKey}" />
                        <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}" Color="{DynamicResource FloatBarButtonButtonBackgroundPressedKey}" />
                        <!--  定义按钮样式  -->
                        <Style x:Key="FloatBarButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundKey}}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="{StaticResource {x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <ResourceDictionary.MergedDictionaries>
                            <ResourceDictionary Source="/Resources/DrawShapeImageDictionary.xaml" />
                        </ResourceDictionary.MergedDictionaries>
                    </ResourceDictionary>
                </ikw:SimpleStackPanel.Resources>



                <Border

                    x:Name="BorderFloatingBarMoveControls"

                    Width="36"

                    Height="36"

                    Background="{DynamicResource FloatBarBackground}"

                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                    BorderThickness="1"

                    CornerRadius="5"

                    MouseDown="SymbolIconEmoji_MouseDown"

                    MouseUp="SymbolIconEmoji_MouseUp">

                    <ikw:SimpleStackPanel

                        Margin="0,5,0,5"

                        HorizontalAlignment="Center"

                        Orientation="Horizontal">

                        <ui:FontIcon

                            Name="SymbolIconEmoji1"

                            Width="28"

                            Height="22"

                            FontFamily="{StaticResource FluentIconFontFamily}"

                            Foreground="{DynamicResource FloatBarForeground}"

                            Glyph="&#xe76e;" />

                        <ui:FontIcon

                            Name="SymbolIconEmoji2"

                            Width="0"

                            Height="22"

                            FontFamily="{StaticResource FluentIconFontFamily}"

                            Foreground="{DynamicResource FloatBarForeground}"

                            Glyph="&#xe899;" />

                    </ikw:SimpleStackPanel>

                </Border>

                <Border

                    Name="BorderFloatingBarMainControls"

                    Height="36"

                    Margin="2,0,0,0"

                    Padding="2,1"

                    Background="{DynamicResource FloatBarBackground}"

                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                    BorderThickness="1"

                    CornerRadius="5"

                    Visibility="Visible">

                    <ikw:SimpleStackPanel

                        Name="StackPanelFloatingBar"

                        Margin="2,0"

                        Orientation="Horizontal">

                        <Button

                            Width="30"

                            Height="32"

                            Margin="-2,0,-2,0"

                            Padding="0"

                            BorderThickness="0"

                            Click="CursorIcon_Click">

                            <ikw:SimpleStackPanel

                                Width="28"

                                HorizontalAlignment="Center"

                                Background="Transparent"

                                Orientation="Vertical">

                                <ui:FontIcon

                                    Width="30"

                                    Height="22"

                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                    FontSize="16"

                                    Foreground="{DynamicResource FloatBarForeground}"

                                    Glyph="&#xe8b0;" />

                                <TextBlock

                                    x:Name="FloatBarSelectIconTextBlock"

                                    Margin="1,-1,0,0"

                                    FontSize="8"

                                    Foreground="{DynamicResource FloatBarForeground}"

                                    Text="鼠标"

                                    TextAlignment="Center" />

                            </ikw:SimpleStackPanel>

                        </Button>

                        <Button

                            Width="30"

                            Height="32"

                            Padding="0"

                            BorderThickness="0"

                            Click="PenIcon_Click">

                            <ikw:SimpleStackPanel

                                Name="Pen_Icon"

                                Width="30"

                                HorizontalAlignment="Center"

                                Background="Transparent"

                                Orientation="Vertical">

                                <ui:FontIcon

                                    x:Name="Icon_Pen"

                                    Width="30"

                                    Height="22"

                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                    FontSize="16"

                                    Foreground="{DynamicResource FloatBarForeground}"

                                    Glyph="&#xee56;" />

                                <TextBlock

                                    Margin="1,-1,0,0"

                                    FontSize="8"

                                    Foreground="{DynamicResource FloatBarForeground}"

                                    Text="批注"

                                    TextAlignment="Center"

                                    Visibility="{Binding ElementName=FloatBarSelectIconTextBlock, Path=Visibility}" />

                            </ikw:SimpleStackPanel>

                        </Button>

                        <Button

                            Width="30"

                            Height="32"

                            Padding="0"

                            BorderThickness="0"

                            Click="SymbolIconDelete_MouseUp">

                            <ikw:SimpleStackPanel

                                Width="30"

                                HorizontalAlignment="Center"

                                Background="Transparent"

                                Orientation="Vertical">

                                <ui:FontIcon

                                    Width="30"

                                    Height="22"

                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                    FontSize="16"

                                    Foreground="{DynamicResource FloatBarForeground}"

                                    Glyph="&#xe74d;" />

                                <TextBlock

                                    Margin="1,-1,0,0"

                                    FontSize="8"

                                    Foreground="{DynamicResource FloatBarForeground}"

                                    Text="清空"

                                    TextAlignment="Center"

                                    Visibility="{Binding ElementName=FloatBarSelectIconTextBlock, Path=Visibility}" />

                            </ikw:SimpleStackPanel>

                        </Button>

                        <ikw:SimpleStackPanel

                            Name="StackPanelCanvasControls"

                            Orientation="{Binding ElementName=StackPanelFloatingBar, Path=Orientation}"

                            Visibility="Visible">

                            <Grid Width="0">

                                <Border

                                    x:Name="PenPalette"

                                    Margin="-131,-190,-239,35"

                                    Background="{DynamicResource FloatBarBackground}"

                                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="5"

                                    Visibility="Visible">

                                    <ikw:SimpleStackPanel>

                                        <Border

                                            Margin="-1,-1,-1,0"

                                            Padding="15,5"

                                            Background="{DynamicResource FloatBarTitleBackground}"

                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                            BorderThickness="1"

                                            CornerRadius="5,5,0,0">

                                            <TextBlock

                                                FontWeight="Bold"

                                                Foreground="{DynamicResource FloatBarForeground}"

                                                Text="墨迹选项" />

                                        </Border>

                                        <ikw:SimpleStackPanel Orientation="Horizontal">

                                            <Viewbox Width="245">

                                                <ikw:SimpleStackPanel Margin="20,10">

                                                    <Viewbox

                                                        Height="80"

                                                        HorizontalAlignment="Center"

                                                        VerticalAlignment="Center">

                                                        <ikw:SimpleStackPanel>

                                                            <Controls:UniformGrid

                                                                Width="310"

                                                                Height="55"

                                                                Columns="2">

                                                                <ikw:SimpleStackPanel Height="35" Orientation="Horizontal">

                                                                    <Label

                                                                        Margin="0,0,12,0"

                                                                        VerticalAlignment="Center"

                                                                        Content="笔锋"

                                                                        FontSize="15"

                                                                        Foreground="{DynamicResource FloatBarForeground}" />

                                                                    <ComboBox

                                                                        x:Name="ComboBoxPenStyle"

                                                                        Height="30"

                                                                        VerticalAlignment="Center"

                                                                        SelectedIndex="0"

                                                                        SelectionChanged="ComboBoxPenStyle_SelectionChanged">

                                                                        <ComboBoxItem Content="点集笔锋" />

                                                                        <ComboBoxItem Content="速率笔锋" />

                                                                        <ComboBoxItem Content="关闭笔锋" />

                                                                    </ComboBox>

                                                                </ikw:SimpleStackPanel>

                                                                <ikw:SimpleStackPanel

                                                                    Margin="0,-5,0,-5"

                                                                    HorizontalAlignment="Right"

                                                                    VerticalAlignment="Center">

                                                                    <ikw:SimpleStackPanel

                                                                        x:Name="NibModeSimpleStackPanel"

                                                                        Width="135"

                                                                        Orientation="Horizontal">

                                                                        <Label

                                                                            VerticalAlignment="Center"

                                                                            Content="笔尖模式"

                                                                            FontSize="15" />

                                                                        <ui:ToggleSwitch

                                                                            x:Name="ToggleSwitchEnableNibMode"

                                                                            Width="70"

                                                                            MinWidth="0"

                                                                            Margin="10,0,0,0"

                                                                            IsOn="True"

                                                                            OffContent="关"

                                                                            OnContent="开"

                                                                            Toggled="ToggleSwitchEnableNibMode_Toggled" />

                                                                    </ikw:SimpleStackPanel>

                                                                    <ikw:SimpleStackPanel Width="135" Orientation="Horizontal">

                                                                        <Label

                                                                            Margin="0,0,10,0"

                                                                            VerticalAlignment="Center"

                                                                            Content="墨迹识别"

                                                                            FontSize="15"

                                                                            Foreground="{DynamicResource FloatBarForeground}" />

                                                                        <ui:ToggleSwitch

                                                                            Width="70"

                                                                            MinWidth="0"

                                                                            Foreground="{DynamicResource FloatBarForeground}"

                                                                            IsOn="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ToggleSwitchEnableInkToShapeBridge.IsOn}"

                                                                            OffContent="关"

                                                                            OnContent="开"

                                                                            Toggled="ToggleSwitchEnableInkToShape_Toggled" />

                                                                    </ikw:SimpleStackPanel>

                                                                </ikw:SimpleStackPanel>

                                                            </Controls:UniformGrid>

                                                            <StackPanel Height="30" Orientation="Horizontal">

                                                                <Label

                                                                    Margin="0,0,10,0"

                                                                    VerticalAlignment="Center"

                                                                    Content="粗细"

                                                                    FontSize="15"

                                                                    Foreground="{DynamicResource FloatBarForeground}" />

                                                                <Slider

                                                                    x:Name="InkWidthSlider"

                                                                    Width="250"

                                                                    FontSize="20"

                                                                    IsSnapToTickEnabled="True"

                                                                    Maximum="30"

                                                                    Minimum="1"

                                                                    TickFrequency="1"

                                                                    TickPlacement="None"

                                                                    ValueChanged="InkWidthSlider_ValueChanged"

                                                                    Value="5" />

                                                                <TextBlock

                                                                    Margin="10,0,0,8"

                                                                    VerticalAlignment="Bottom"

                                                                    FontSize="14"

                                                                    Foreground="{DynamicResource FloatBarForeground}"

                                                                    Text="{Binding Value, ElementName=InkWidthSlider, Mode=OneWay}" />

                                                            </StackPanel>

                                                        </ikw:SimpleStackPanel>

                                                    </Viewbox>

                                                    <ikw:SimpleStackPanel Width="310">

                                                        <Border

                                                            Width="310"

                                                            Height="120"

                                                            BorderBrush="Black"

                                                            BorderThickness="0"

                                                            CornerRadius="5">

                                                            <Controls:UniformGrid Height="120" Rows="2">

                                                                <ikw:SimpleStackPanel

                                                                    Width="310"

                                                                    Height="50"

                                                                    Orientation="Horizontal">

                                                                    <Controls:UniformGrid Width="310" Columns="5">

                                                                        <Border

                                                                            Width="50"

                                                                            Background="Transparent"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseDown="Border_MouseDown"

                                                                            MouseUp="ColorThemeSwitch_MouseUp">

                                                                            <Grid Margin="5">

                                                                                <ui:FontIcon

                                                                                    x:Name="ColorThemeSwitchIcon"

                                                                                    Width="26"

                                                                                    Height="26"

                                                                                    VerticalAlignment="Top"

                                                                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                                                                    Foreground="{DynamicResource FloatBarForeground}"

                                                                                    Glyph="&#xe706;" />

                                                                                <TextBlock

                                                                                    x:Name="ColorThemeSwitchTextBlock"

                                                                                    HorizontalAlignment="Center"

                                                                                    VerticalAlignment="Bottom"

                                                                                    FontSize="13"

                                                                                    Foreground="{DynamicResource FloatBarForeground}"

                                                                                    Text="亮系" />

                                                                            </Grid>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorBlack"

                                                                            Width="50"

                                                                            Background="Black"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorBlack_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorBlackContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorWhite"

                                                                            Width="50"

                                                                            Background="White"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorWhite_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorWhiteContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-black.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorRed"

                                                                            Width="50"

                                                                            Background="#dc2626"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorRed_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorRedContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorPink"

                                                                            Width="50"

                                                                            Background="#c72ec7"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorPink_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorPinkContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                    </Controls:UniformGrid>

                                                                </ikw:SimpleStackPanel>

                                                                <ikw:SimpleStackPanel

                                                                    Width="310"

                                                                    Height="50"

                                                                    Orientation="Horizontal">

                                                                    <Controls:UniformGrid Width="310" Columns="5">

                                                                        <Border

                                                                            x:Name="BorderPenColorOrange"

                                                                            Width="50"

                                                                            Background="#ea580c"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorOrange_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorOrangeContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorYellow"

                                                                            Width="50"

                                                                            Background="#eab308"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorYellow_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorYellowContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorGreen"

                                                                            Width="50"

                                                                            Background="#16a34a"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorGreen_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorGreenContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorTeal"

                                                                            Width="50"

                                                                            Background="#0d9488"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorTeal_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorTealContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                        <Border

                                                                            x:Name="BorderPenColorBlue"

                                                                            Width="50"

                                                                            Background="#2563eb"

                                                                            BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                            BorderThickness="1.5"

                                                                            CornerRadius="100"

                                                                            MouseUp="BtnColorBlue_Click">

                                                                            <Viewbox

                                                                                x:Name="ViewboxBtnColorBlueContent"

                                                                                Margin="8"

                                                                                Visibility="Collapsed">

                                                                                <Image

                                                                                    Width="24"

                                                                                    Height="24"

                                                                                    VerticalAlignment="Top"

                                                                                    RenderOptions.BitmapScalingMode="HighQuality"

                                                                                    Source="/Resources/Icons-png/checked-white.png" />

                                                                            </Viewbox>

                                                                        </Border>

                                                                    </Controls:UniformGrid>

                                                                </ikw:SimpleStackPanel>

                                                            </Controls:UniformGrid>

                                                        </Border>

                                                    </ikw:SimpleStackPanel>

                                                </ikw:SimpleStackPanel>

                                            </Viewbox>

                                            <ikw:SimpleStackPanel Width="115">

                                                <TextBlock

                                                    Margin="0,40,0,5"

                                                    FontWeight="Bold"

                                                    Foreground="{DynamicResource FloatBarForeground}"

                                                    Text="荧光笔"

                                                    TextAlignment="Center" />



                                                <ikw:SimpleStackPanel

                                                    VerticalAlignment="Center"

                                                    Orientation="Horizontal"

                                                    Spacing="5">

                                                    <TextBlock

                                                        FontSize="10"

                                                        Foreground="{DynamicResource FloatBarForeground}"

                                                        Text="不透明度"

                                                        TextAlignment="Left" />

                                                    <Viewbox Height="16">

                                                        <Slider

                                                            x:Name="InkAlphaSlider"

                                                            Width="140"

                                                            IsSnapToTickEnabled="True"

                                                            Maximum="240"

                                                            Minimum="20"

                                                            TickFrequency="20"

                                                            TickPlacement="None"

                                                            ValueChanged="InkAlphaSlider_ValueChanged"

                                                            Value="120" />

                                                    </Viewbox>

                                                </ikw:SimpleStackPanel>



                                                <ikw:SimpleStackPanel>

                                                    <Controls:UniformGrid Height="65" Rows="2">

                                                        <ikw:SimpleStackPanel

                                                            Width="115"

                                                            Height="25"

                                                            Orientation="Horizontal">

                                                            <Controls:UniformGrid Width="115" Columns="3">

                                                                <Border

                                                                    x:Name="BorderHighlighterColorRed"

                                                                    Width="30"

                                                                    Background="#ff5e53"

                                                                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                    BorderThickness="1"

                                                                    CornerRadius="4"

                                                                    MouseUp="BtnHighlighterColorRed_Click">

                                                                    <Viewbox

                                                                        x:Name="ViewboxBtnHighlighterColorRedContent"

                                                                        Margin="2"

                                                                        Visibility="Collapsed">

                                                                        <Image

                                                                            Width="28"

                                                                            Height="28"

                                                                            VerticalAlignment="Top"

                                                                            RenderOptions.BitmapScalingMode="HighQuality"

                                                                            Source="/Resources/Icons-png/checked-white.png" />

                                                                    </Viewbox>

                                                                </Border>

                                                                <Border

                                                                    x:Name="BorderHighlighterColorOrange"

                                                                    Width="30"

                                                                    Background="#ff700d"

                                                                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                    BorderThickness="1"

                                                                    CornerRadius="4"

                                                                    MouseUp="BtnHighlighterColorOrange_Click">

                                                                    <Viewbox

                                                                        x:Name="ViewboxBtnHighlighterColorOrangeContent"

                                                                        Margin="2"

                                                                        Visibility="Collapsed">

                                                                        <Image

                                                                            Width="28"

                                                                            Height="28"

                                                                            VerticalAlignment="Top"

                                                                            RenderOptions.BitmapScalingMode="HighQuality"

                                                                            Source="/Resources/Icons-png/checked-white.png" />

                                                                    </Viewbox>

                                                                </Border>

                                                                <Border

                                                                    x:Name="BorderHighlighterColorYellow"

                                                                    Width="30"

                                                                    Background="#ffd308"

                                                                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                    BorderThickness="1"

                                                                    CornerRadius="4"

                                                                    MouseUp="BtnHighlighterColorYellow_Click">

                                                                    <Viewbox

                                                                        x:Name="ViewboxBtnHighlighterColorYellowContent"

                                                                        Margin="2"

                                                                        Visibility="Collapsed">

                                                                        <Image

                                                                            Width="28"

                                                                            Height="28"

                                                                            VerticalAlignment="Top"

                                                                            RenderOptions.BitmapScalingMode="HighQuality"

                                                                            Source="/Resources/Icons-png/checked-white.png" />

                                                                    </Viewbox>

                                                                </Border>

                                                            </Controls:UniformGrid>

                                                        </ikw:SimpleStackPanel>

                                                        <ikw:SimpleStackPanel

                                                            Width="115"

                                                            Height="25"

                                                            Orientation="Horizontal">

                                                            <Controls:UniformGrid Width="115" Columns="3">

                                                                <Border

                                                                    x:Name="BorderHighlighterColorTeal"

                                                                    Width="30"

                                                                    Background="#10baab"

                                                                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                    BorderThickness="1"

                                                                    CornerRadius="4"

                                                                    MouseUp="BtnHighlighterColorTeal_Click">

                                                                    <Viewbox

                                                                        x:Name="ViewboxBtnHighlighterColorTealContent"

                                                                        Margin="2"

                                                                        Visibility="Collapsed">

                                                                        <Image

                                                                            Width="28"

                                                                            Height="28"

                                                                            VerticalAlignment="Top"

                                                                            RenderOptions.BitmapScalingMode="HighQuality"

                                                                            Source="/Resources/Icons-png/checked-white.png" />

                                                                    </Viewbox>

                                                                </Border>

                                                                <Border

                                                                    x:Name="BorderHighlighterColorBlue"

                                                                    Width="30"

                                                                    Background="#4a76ff"

                                                                    BorderBrush="{DynamicResource FloatBarBorderBrush}"

                                                                    BorderThickness="1"

                                                                    CornerRadius="4"

