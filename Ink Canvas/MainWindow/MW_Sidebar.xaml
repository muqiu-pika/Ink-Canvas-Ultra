<UserControl
    x:Class="Ink_Canvas.MW_Sidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:local="clr-namespace:Ink_Canvas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    mc:Ignorable="d">
    <Grid>
        <!--  // 侧边栏 //  -->

        <Viewbox

            x:Name="LeftSidePanel"

            Width="30"

            Height="50"

            Margin="-40,0,0,-150"

            HorizontalAlignment="Left"

            VerticalAlignment="Center"

            MouseUp="UnFoldFloatingBar_MouseUp"

            Visibility="Visible">

            <ikw:SimpleStackPanel>

                <Border

                    Width="30"

                    Height="50"

                    Background="LightGray"

                    CornerRadius="5"

                    Opacity="0.4">

                    <Image

                        Width="30"

                        Height="50"

                        Margin="0,0,-15,0"

                        RenderOptions.BitmapScalingMode="HighQuality"

                        Source="/Resources/Icons-png/penUpright.png" />

                </Border>

            </ikw:SimpleStackPanel>

        </Viewbox>

        <Viewbox

            x:Name="RightSidePanel"

            Width="30"

            Height="50"

            Margin="0,0,-40,-150"

            HorizontalAlignment="Right"

            VerticalAlignment="Center"

            MouseUp="UnFoldFloatingBar_MouseUp"

            Visibility="{Binding ElementName=LeftSidePanel, Path=Visibility}">

            <ikw:SimpleStackPanel>

                <Border

                    Width="30"

                    Height="50"

                    Background="LightGray"

                    CornerRadius="5"

                    Opacity="0.4">

                    <Image

                        Width="30"

                        Height="50"

                        Margin="-15,0,0,0"

                        RenderOptions.BitmapScalingMode="HighQuality"

                        Source="/Resources/Icons-png/penUpright.png" />

                </Border>

            </ikw:SimpleStackPanel>

        </Viewbox>

        <!--  视频展台侧栏  -->

        <Border

            x:Name="VideoPresenterSidebar"

            Width="350"

            Height="Auto"

            HorizontalAlignment="Left"

            VerticalAlignment="Stretch"

            Background="{DynamicResource BoardBarBackground}"

            BorderBrush="{DynamicResource BoardBarBorderBrush}"

            BorderThickness="0,0,1,0"

            Visibility="Collapsed">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="50" />

                    <RowDefinition Height="*" />

                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="60" />

                </Grid.RowDefinitions>



                <!--  顶部标题栏  -->

                <Grid Grid.Row="0" Height="50" VerticalAlignment="Top">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="50" />

                    </Grid.ColumnDefinitions>

                    <TextBlock

                        Grid.Column="0"

                        Margin="15,0,0,0"

                        HorizontalAlignment="Left"

                        VerticalAlignment="Center"

                        FontSize="16"

                        FontWeight="Bold"

                        Foreground="{DynamicResource BoardBarForeground}"

                        Text="视频展台" />

                    <Button

                        Grid.Column="1"

                        Width="50"

                        Height="50"

                        Padding="0"

                        BorderThickness="0"

                        Click="BtnCloseVideoPresenter_Click">

                        <Border

                            Width="50"

                            Height="50"

                            Background="Transparent">

                            <ui:FontIcon

                                Width="24"

                                Height="24"

                                HorizontalAlignment="Center"

                                VerticalAlignment="Center"

                                FontFamily="{StaticResource FluentIconFontFamily}"

                                FontSize="20"

                                Foreground="{DynamicResource BoardBarForeground}"

                                Glyph="&#xe711;" />

                        </Border>

                    </Button>

                </Grid>



                <!--  照片显示区域  -->

                <Border x:Name="CapturedPhotosBorder" Grid.Row="1" Margin="10,10,10,2" Padding="10,10,10,10">

                    <Grid>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto" />

                            <RowDefinition Height="*" />

                            <RowDefinition Height="Auto" />

                        </Grid.RowDefinitions>

                        <TextBlock

                            Grid.Row="0"

                            x:Name="CapturedPhotosTitleTextBlock"

                            Margin="0,0,0,8"

                            HorizontalAlignment="Left"

                            FontSize="12"

                            FontWeight="SemiBold"

                            Foreground="{DynamicResource BoardBarForeground}"

                            Text="拍摄照片" />

                        <ScrollViewer

                            Grid.Row="1"

                            x:Name="CapturedPhotosScrollViewer"

                            VerticalScrollBarVisibility="Auto"

                            ManipulationBoundaryFeedback="SCManipulationBoundaryFeedback"

                            PanningMode="VerticalFirst">

                            <StackPanel x:Name="CapturedPhotosStackPanel" Margin="0,0,0,5" />

                        </ScrollViewer>

                        <Button

                            Grid.Row="2"

                            x:Name="BtnClearAllContent"

                            Width="Auto"

                            Height="36"

                            Margin="0,8,0,0"

                            HorizontalAlignment="Center"

                            Background="{DynamicResource BoardBarButtonBackground}"

                            BorderBrush="#C42B1C"

                            BorderThickness="1"

                            Click="BtnClearAllContent_Click">

                            <StackPanel Orientation="Horizontal">

                                <ui:FontIcon

                                    Width="16"

                                    Height="16"

                                    Margin="0,0,5,0"

                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                    FontSize="14"

                                    Foreground="#C42B1C"

                                    Glyph="&#xE74D;" />

                                <TextBlock

                                    FontSize="12"

                                    FontWeight="SemiBold"

                                    Foreground="#C42B1C"

                                    Text="清除所有内容" />

                            </StackPanel>

                        </Button>

                    </Grid>

                </Border>



                <!--  设备选择区域  -->

                <Border Grid.Row="2" Margin="10,2,10,5" Padding="10">

                    <StackPanel>

                        <TextBlock

                            Margin="0,0,0,8"

                            HorizontalAlignment="Left"

                            FontSize="12"

                            FontWeight="SemiBold"

                            Foreground="{DynamicResource BoardBarForeground}"

                            Text="摄像头设备" />

                        <ScrollViewer

                            x:Name="CameraDevicesScrollViewer"

                            MaxHeight="120"

                            VerticalScrollBarVisibility="Auto"

                            ManipulationBoundaryFeedback="SCManipulationBoundaryFeedback"

                            PanningMode="VerticalFirst">

                            <StackPanel x:Name="CameraDevicesStackPanel" />

                        </ScrollViewer>

                    </StackPanel>

                </Border>



                <!--  底部按钮区域  -->

                <Grid Grid.Row="3" Height="60">

                    <StackPanel

                        Margin="10,5"

                        HorizontalAlignment="Center"

                        VerticalAlignment="Center"

                        Orientation="Horizontal">

                        <ToggleButton

                            x:Name="CheckBoxEnablePhotoCorrection"

                            Width="110"

                            Height="40"

                            Margin="3,0"

                            Background="{DynamicResource BoardBarButtonBackground}"

                            BorderBrush="{DynamicResource BoardBarBorderBrush}"

                            BorderThickness="1"

                            Checked="CheckBoxEnablePhotoCorrection_Checked"

                            Unchecked="CheckBoxEnablePhotoCorrection_Unchecked">

                            <StackPanel Orientation="Horizontal">

                                <ui:FontIcon

                                    Width="16"

                                    Height="16"

                                    Margin="0,0,5,0"

                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                    FontSize="14"

                                    Foreground="{DynamicResource BoardBarForeground}"

                                    Glyph="&#xE8D2;" />

                                <TextBlock

                                    FontSize="12"

                                    FontWeight="SemiBold"

                                    Foreground="{DynamicResource BoardBarForeground}"

                                    Text="实时矫正" />

                            </StackPanel>

                        </ToggleButton>

                        <Button

                            x:Name="BtnCapturePhoto"

                            Width="90"

                            Height="40"

                            Margin="3,0"

                            Background="{DynamicResource BoardBarButtonBackground}"

                            BorderBrush="{DynamicResource BoardBarBorderBrush}"

                            BorderThickness="1"

                            Click="BtnCapturePhoto_Click">

                            <StackPanel Orientation="Horizontal">

                                <ui:FontIcon

                                    Width="16"

                                    Height="16"

                                    Margin="0,0,5,0"

                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                    FontSize="14"

                                    Foreground="{DynamicResource BoardBarForeground}"

                                    Glyph="&#xE722;" />

                                <TextBlock

                                    FontSize="12"

                                    FontWeight="SemiBold"

                                    Foreground="{DynamicResource BoardBarForeground}"

                                    Text="拍照" />

                            </StackPanel>

                        </Button>

                        <Button

                            x:Name="BtnRotateImage"

                            Width="90"

                            Height="40"

                            Margin="3,0"

                            Background="{DynamicResource BoardBarButtonBackground}"

                            BorderBrush="{DynamicResource BoardBarBorderBrush}"

                            BorderThickness="1"

                            Click="BtnRotateImage_Click">

                            <StackPanel Orientation="Horizontal">

                                <ui:FontIcon

                                    Width="16"

                                    Height="16"

                                    Margin="0,0,5,0"

                                    FontFamily="{StaticResource FluentIconFontFamily}"

                                    FontSize="14"

                                    Foreground="{DynamicResource BoardBarForeground}"

                                    Glyph="&#xE7AD;" />

                                <TextBlock

                                    FontSize="12"

                                    FontWeight="SemiBold"

                                    Foreground="{DynamicResource BoardBarForeground}"

                                    Text="旋转" />

                            </StackPanel>

                        </Button>

                    </StackPanel>

                </Grid>

            </Grid>

        </Border>

    </Grid>
</UserControl>

